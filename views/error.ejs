<% layout('/layouts/biolerplate') %>

<div class="container d-flex flex-column align-items-center justify-content-center" style="min-height: 80vh;">
  
  <div class="row w-100 justify-content-center">
    <div class="col-11 col-md-6 text-center p-5 shadow border-0" style="border-radius: 24px; background-color: #ffffff; box-shadow: 0px 15px 35px rgba(0,0,0,0.05) !important;">
            <div class="mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#ff385c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="feather feather-frown" style="animation: bounce 2s infinite;">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M16 16s-1.5-2-4-2-4 2-4 2"></path>
          <line x1="9" y1="9" x2="9.01" y2="9"></line>
          <line x1="15" y1="9" x2="15.01" y2="9"></line>
        </svg>
      </div>
      <h3 class="fw-bold mb-3" style="color: #222222;">Something went wrong</h3>
            <p class="fs-5 text-muted mb-4 px-3" style="line-height: 1.6;">
        <%= message %>
      </p>
      <a href="/listings" class="btn btn-dark px-4 py-2 fw-bold shadow-sm" style="border-radius: 10px; background-color: #222222; border: none;">
        Back to Home page!
      </a>
    </div>
  </div>
</div>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>
